up [ GunUSingle ] -> [ ArrowU GunUSingle ]
down [ GunDSingle ] -> [ ArrowD GunDSingle ]
left [ GunLSingle ] -> [ ArrowL GunLSingle ]
right [ GunRSingle ] -> [ ArrowR GunRSingle ]

