{
  "name": "puzzlescript-vscode",
  "displayName": "PuzzleScript",
  "description": "PuzzleScript editor support powered by the existing PuzzleScript JavaScript editor logic.",
  "version": "0.1.0",
  "publisher": "puzzlescript",
  "license": "MIT",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:puzzlescript",
    "onDebug:puzzlescript",
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "configuration": {
      "title": "PuzzleScript",
      "properties": {
        "puzzlescript.repoRoot": {
          "type": "string",
          "default": "",
          "description": "Path to a PuzzleScript repository checkout. Empty uses the repository root when developing this extension from the PuzzleScript tree."
        }
      }
    },
    "commands": [
      {
        "command": "puzzlescript.runCurrentGame",
        "title": "Run Current Game",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.runCurrentGameLevel",
        "title": "Run Current Level",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.setLanguageMode",
        "title": "Set Current File as PuzzleScript",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugCurrentGame",
        "title": "Debug Current Game",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugInputUp",
        "title": "Debug: Input Up",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugInputDown",
        "title": "Debug: Input Down",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugInputLeft",
        "title": "Debug: Input Left",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugInputRight",
        "title": "Debug: Input Right",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugInputAction",
        "title": "Debug: Input Action",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugTick",
        "title": "Debug: Tick",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugUndo",
        "title": "Debug: Undo",
        "category": "PuzzleScript"
      },
      {
        "command": "puzzlescript.debugRestart",
        "title": "Debug: Restart",
        "category": "PuzzleScript"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "puzzlescript.runCurrentGame",
          "when": "resourceLangId == puzzlescript",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "puzzlescript.runCurrentGame",
          "when": "resourceLangId == puzzlescript",
          "group": "navigation"
        },
        {
          "command": "puzzlescript.debugCurrentGame",
          "when": "resourceLangId == puzzlescript",
          "group": "navigation"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "puzzlescript"
      }
    ],
    "debuggers": [
      {
        "type": "puzzlescript",
        "label": "PuzzleScript",
        "languages": [
          "puzzlescript"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the PuzzleScript source file.",
                "default": "${file}"
              },
              "level": {
                "type": "number",
                "description": "Optional zero-based level index to load before debugging."
              },
              "seed": {
                "type": "string",
                "description": "Optional random seed for the debug session."
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause immediately after compiling the game.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "puzzlescript",
            "request": "launch",
            "name": "Debug PuzzleScript",
            "program": "${file}",
            "stopOnEntry": false
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "puzzlescript",
        "aliases": [
          "PuzzleScript",
          "puzzlescript"
        ],
        "extensions": [
          ".puzzlescript",
          ".ps"
        ],
        "configuration": "./language-configuration/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "puzzlescript",
        "scopeName": "source.puzzlescript",
        "path": "./syntaxes/puzzlescript.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      { "id": "psHeader", "superType": "keyword", "description": "PuzzleScript section header or separator" },
      { "id": "psName", "superType": "variable", "description": "PuzzleScript object or legend name" },
      { "id": "psColor", "superType": "number", "description": "PuzzleScript color literal or sprite color index" },
      { "id": "psAssignment", "superType": "operator", "description": "PuzzleScript legend assignment" },
      { "id": "psLogic", "superType": "keyword", "description": "PuzzleScript logic word" },
      { "id": "psSound", "superType": "event", "description": "PuzzleScript sound token" },
      { "id": "psDirection", "superType": "enumMember", "description": "PuzzleScript direction token" },
      { "id": "psArrow", "superType": "operator", "description": "PuzzleScript rule arrow" },
      { "id": "psBracket", "superType": "operator", "description": "PuzzleScript rule bracket or separator" },
      { "id": "psCommand", "superType": "keyword", "description": "PuzzleScript rule command" },
      { "id": "psMessage", "superType": "string", "description": "PuzzleScript message text" },
      { "id": "psMetadata", "superType": "property", "description": "PuzzleScript metadata" },
      { "id": "psLevel", "superType": "string", "description": "PuzzleScript level glyph" },
      { "id": "psComment", "superType": "comment", "description": "PuzzleScript comment" },
      { "id": "psError", "superType": "regexp", "description": "PuzzleScript parser error token" }
    ],
    "semanticTokenModifiers": [
      { "id": "spriteColor", "description": "Token carries a concrete PuzzleScript palette color" },
      { "id": "boldColor", "description": "Token should be emphasized as a sprite color index" },
      { "id": "fadeColor", "description": "Token is a transparent or faded sprite cell" },
      { "id": "metadataText", "description": "Token is metadata value text" },
      { "id": "soundEvent", "description": "Token is a sound event" },
      { "id": "soundVerb", "description": "Token is a sound verb" },
      { "id": "messageVerb", "description": "Token is a message command" }
    ]
  },
  "scripts": {
    "test": "node ./test/editor-intelligence.test.js && node ./test/syntax-highlighting.test.js && node ./test/debugger.test.js && node ./test/level-links.test.js",
    "test:syntax": "node ./test/syntax-highlighting.test.js",
    "preview:syntax": "node ./scripts/render-highlight-preview.js"
  },
  "devDependencies": {}
}
